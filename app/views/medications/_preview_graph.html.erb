<% version_selection = local_assigns.fetch(:version_selection, false) %>
<% medication = medication_version.medication %>

<turbo-frame id="graph">
  <div data-controller="medication-preview"
        class="mx-auto w-full md:w-2/3 xl:w-1/2 bg-white border border-rose-100 rounded-2xl overflow-hidden shadow-sm"
        data-medication-preview-plot-value="<%= PkCalculator.for_medication(medication_version).to_json %>">
    <div class="px-5 pt-5 pb-3 flex items-start justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-rose-300 mb-1"><%= t(".pharmacokinetics") %></p>
        <% if version_selection %>
          <%= form_with url: medication_path(medication), id: "version_form", method: :get, data: { turbo_frame: "graph", medication_preview_target: "form" }, class: "mt-5" do |f| %>
            <%= f.select :medication_version_id,
                  medication.versions.map { |v| [v.added_name, v.id] },
                  { selected: medication_version.id },
                  {
                    data: { action: "change->medication-preview#update" },
                    class: "text-lg font-semibold text-zinc-800 bg-transparent border-none outline-none cursor-pointer hover:text-rose-400 transition-colors"
                  } %>
            <noscript>
              <%= f.submit t(".go"), class: "text-sm text-rose-400 underline ml-2" %>
            </noscript>
          <% end %>
      <% end %>
      </div>
      <span class="text-xs bg-rose-50 text-rose-400 border border-rose-100 font-medium px-2.5 py-1 rounded-full">
        <%= t(".single_dose_badge") %>
      </span>
    </div>

    <div data-medication-preview-target="chart" class="w-full px-1"></div>

    <div class="px-5 py-3 border-t border-rose-50 flex flex-col gap-3">
      <% medication_version.medication_version_ingredients.each do |mvi| %>
        <% ingredient = mvi.active_ingredient %>
        <div class="flex items-center gap-1.5 text-xs text-zinc-500">
          <span class="inline-block w-2 h-2 rounded-full <%= mvi.available_for_pk? ? "bg-green-400" : "bg-rose-400" %>"></span>
          <span class="font-medium text-zinc-700"><%= ingredient.name %></span>
          <% if ingredient.half_life.present? %>
            <span class="text-zinc-400">·</span>
            <span>t½ <%= format("%g", ingredient.half_life) %>h</span>
            <span class="text-zinc-400">·</span>
            <span>ke <%= (Math.log(2)/ingredient.half_life).round(2) %>h⁻¹</span>
          <% end %>
          <% if ingredient.absorption_rate.present? %>
            <span class="text-zinc-400">·</span>
            <span>ka <%= format("%g", ingredient.absorption_rate) %>h⁻¹</span>
          <% end %>
          <% if ingredient.volume_of_distribution.present? %>
            <span class="text-zinc-400">·</span>
            <span>Vd <%= format("%g", ingredient.volume_of_distribution) %>L</span>
          <% end %>
          <% unless mvi.available_for_pk? %>
            <span class="text-zinc-400">·</span>
            <span><%= t(".not_available_for_pk") %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
