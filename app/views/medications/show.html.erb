<div class="w-full">
  <div class="flex flex-col md:flex-row justify-between">
    <h3 class="text-3xl md:w-2/3">
      <%= @medication.name %>
      <span class="text-black/50 italic">
        - <%= @medication.active_ingredients.pluck(:name).join(", ") %>
      </span>
    </h3>
    <% if admin? %>
      <div class="my-6 md:my-0 flex items-center gap-2">
        <%= link_to edit_medication_path(@medication), class: "inline-flex items-center justify-center w-9 h-9 rounded-lg border border-zinc-200 bg-white hover:bg-zinc-50 hover:border-zinc-300 transition-colors" do %>
          <%= image_tag "icons/edit.svg", class: "h-4 w-4" %>
        <% end %>
        <%= button_to @medication, method: :delete, data: { turbo_confirm: "Are you sure? This will delete everyones prescriptions as well o.O" }, class: "inline-flex items-center justify-center w-9 h-9 rounded-lg border border-zinc-200 bg-white hover:bg-rose-50 hover:border-rose-300 transition-colors cursor-pointer" do %>
          <%= image_tag "icons/delete.svg", class: "h-4 w-4" %>
        <% end %>
      </div>
    <% end %>
  </div>
  <% if @medication.labeler.present? %>
    <p class="italic">Made by <%= @medication.labeler.name %></p>
  <% end %>

  <% if @medication.categories.any? %>
    <div class="mt-4 flex flex-wrap justify-baseline gap-1">
      <%= render @medication.categories %>
    </div>
  <% end %>

  <div class="my-12 text-lg">
    <%= @medication.notes %>
  </div>

  <turbo-frame id="graph">
    <% unless @medication_version.nil? %>
      <div class="my-12">
        <div data-controller="medication-preview"
            class="mx-auto w-full md:w-2/3 xl:w-1/2 bg-white border border-rose-100 rounded-2xl overflow-hidden shadow-sm"
            data-medication-preview-release-profile-value="<%=
            {
              name: @medication.release_profile.name,
              delay: @medication.medication_release_profile.delay,
              release_duration: @medication.medication_release_profile.release_duration
            }.compact.to_json %>"
            data-medication-preview-ingredients-value="<%=
              @medication_version.medication_version_ingredients.where(unit: [:mg, :g, :mcg]).joins(:active_ingredient).where.not(active_ingredients: { half_life: nil, absorption_rate: nil, volume_of_distribution: nil }).map do |mvi|
                next if mvi.active_ingredient.half_life.blank? || mvi.active_ingredient.absorption_rate.blank? || mvi.active_ingredient.volume_of_distribution.blank?
                multiplier = case mvi.unit
                              when "mg"  then 1.0
                              when "g"   then 1000.0
                              when "mcg" then 0.001
                              else nil
                              end
                next if multiplier.nil?
                {
                  name: mvi.active_ingredient.name,
                  halfLife: mvi.active_ingredient.half_life,
                  amount: mvi.amount * multiplier,
                  absorptionRate: mvi.active_ingredient.absorption_rate,
                  volumeOfDistribution: mvi.active_ingredient.volume_of_distribution
                }
              end.compact.to_json
            %>">

          <div class="px-5 pt-5 pb-3 flex items-start justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-rose-300 mb-1">Pharmacokinetics</p>
              <%= form_with url: medication_path(@medication), method: :get, data: { turbo_frame: "graph" }, class: "mt-5" do |f| %>
                <%= f.select :medication_version_id,
                      @medication.versions.map { |v| [v.added_name, v.id] },
                      { selected: @medication_version.id },
                      {
                        onchange: "this.form.requestSubmit()",
                        class: "text-lg font-semibold text-zinc-800 bg-transparent border-none outline-none cursor-pointer hover:text-rose-400 transition-colors"
                      } %>
                <noscript>
                  <%= f.submit "Go", class: "text-sm text-rose-400 underline ml-2" %>
                </noscript>
              <% end %>
            </div>
            <span class="text-xs bg-rose-50 text-rose-400 border border-rose-100 font-medium px-2.5 py-1 rounded-full">
              Single dose · 24h
            </span>
          </div>

          <div data-medication-preview-target="chart" class="w-full px-1"></div>

          <div class="px-5 py-3 border-t border-rose-50 flex flex-col gap-3">
            <% @medication_version.medication_version_ingredients.each do |mvi| %>
              <% ingredient = mvi.active_ingredient %>
              <div class="flex items-center gap-1.5 text-xs text-zinc-500">
                <span class="inline-block w-2 h-2 rounded-full <%= mvi.available_for_pk? ? "bg-green-400" : "bg-rose-400" %>"></span>
                <span class="font-medium text-zinc-700"><%= ingredient.name %></span>
                <% if ingredient.half_life.present? %>
                  <span class="text-zinc-400">·</span>
                  <span>t½ <%= ingredient.half_life %>h</span>
                  <span class="text-zinc-400">·</span>
                  <span>ke <%= (Math.log(2)/ingredient.half_life).round(2) %>h⁻¹</span>
                <% end %>
                <% if ingredient.absorption_rate.present? %>
                  <span class="text-zinc-400">·</span>
                  <span>ka <%= ingredient.absorption_rate %>h⁻¹</span>
                <% end %>
                <% if ingredient.volume_of_distribution.present? %>
                  <span class="text-zinc-400">·</span>
                  <span>Vd <%= ingredient.volume_of_distribution %>L</span>
                <% end %>
                <% unless mvi.available_for_pk? %>
                  <span class="text-zinc-400">·</span>
                  <span>Not available for pk</span>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </turbo-frame>

  <section class="mt-12">
    <h3 class="text-2xl">Versions</h3>
    <div class="overflow-x-auto -mx-4 px-4">
      <table class="w-full mt-3 text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-xs uppercase tracking-widest text-rose-300">
            <th class="pb-3 pr-8">Name</th>
            <th class="pb-3 pr-8 hidden sm:table-cell">Ingredients</th>
            <% if admin? %>
              <th class="pb-3 pr-8">Add/Remove</th>
              <th class="pb-3">Actions</th>
            <% else %>
              <th class="pb-3">Add/Remove</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% @medication.versions.each do |version| %>
            <tr class="transition-colors hover:bg-zinc-50">
              <td class="py-3 pr-8 font-medium text-zinc-800"><%= version.full_name %></td>
              <td class="py-3 pr-8 font-medium text-zinc-800 hidden sm:table-cell">
                <div class="text-xs flex items-center">
                  <ul>
                    <% version.medication_version_ingredients.each do |mvi| %>
                      <li><%= "#{format("%g", mvi.amount)}#{mvi.unit} #{mvi.active_ingredient.name}" %></li>
                    <% end %>
                  </ul>
                  <span class="mx-1">/</span>
                  <span><%= @medication.form.name %></span>
                </div>
              </td>
              <td class="py-3 pr-4 font-medium text-zinc-800">
                <% unless Current.user.prescriptions.where("medication_version_id = ?", version.id).any? %>
                  <%= link_to "＋ Add", new_medication_version_prescription_path(medication_version_id: version.id), method: :get,
                    class: "cursor-pointer px-3 py-1.5 bg-white border border-rose-300 text-rose-400 text-xs font-semibold rounded-lg hover:bg-rose-300 hover:text-white transition-colors" %>
                <% else %>
                  <%= button_to "- Remove", Current.user.prescriptions.where("medication_version_id = ?", version.id).first, method: :delete,
                    class: "cursor-pointer px-3 py-1.5 bg-white border border-rose-300 text-rose-400 text-xs font-semibold rounded-lg hover:bg-rose-300 hover:text-white transition-colors" %>
                <% end %>
              </td>
              <% if admin? %>
                <td class="py-3 flex">
                  <%= link_to edit_medication_version_path(version), class: "mx-1" do %>
                    <%= image_tag "icons/edit.svg", class: "aspect-square h-[1.5em]" %>
                  <% end %>
                  <%= button_to medication_version_path(version), method: :delete, data: { turbo_confirm: "Are you sure, this will remove everyones prescriptions?" }, class: "mx-1" do %>
                    <%= image_tag "icons/delete.svg", class: "hover:cursor-pointer aspect-square h-[1.5em]" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if admin? %>
      <%= link_to "New version", new_medication_medication_version_path(@medication) %>
    <% end %>
  </section>
</div>
