<% content_for(:title, @medication.name) %>

<div class="w-full">
  <div class="flex flex-col md:flex-row justify-between">
    <h3 class="text-3xl font-semibold text-gray-800 md:w-2/3">
      <%= @medication.name %>
      <span class="text-gray-400 italic font-normal">
        - <%= @medication.active_ingredients.pluck(:name).join(", ") %>
      </span>
    </h3>
    <% if admin? %>
      <div class="my-6 md:my-0 flex items-center gap-2">
        <%= link_to edit_medication_path(@medication), class: "inline-flex items-center justify-center w-9 h-9 rounded-lg border border-zinc-200 bg-white hover:bg-zinc-50 hover:border-zinc-300 transition-colors" do %>
          <%= image_tag "icons/edit.svg", class: "h-4 w-4" %>
        <% end %>
        <%= button_to @medication, method: :delete, data: { turbo_confirm: t(".confirm_delete") }, class: "inline-flex items-center justify-center w-9 h-9 rounded-lg border border-zinc-200 bg-white hover:bg-rose-50 hover:border-rose-300 transition-colors cursor-pointer" do %>
          <%= image_tag "icons/delete.svg", class: "h-4 w-4" %>
        <% end %>
      </div>
    <% end %>
  </div>
  <% if @medication.labeler.present? %>
    <p class="italic"><%= t(".made_by", labeler: @medication.labeler.name) %></p>
  <% end %>

  <% if @medication.categories.any? %>
    <div class="mt-4 flex flex-wrap justify-baseline gap-1">
      <%= render @medication.categories %>
    </div>
  <% end %>

  <div class="my-12 text-lg">
    <%= @medication.notes %>
  </div>


  <% unless @medication.nil? %>
    <%= render "preview_graph", medication_version: @medication_version, version_selection: true %>
  <% end %>


  <section class="mt-12">
    <h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8"><%= t(".versions") %></h3>
    <div class="overflow-x-auto -mx-4 px-4">
      <table class="w-full mt-3 text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-xs uppercase tracking-widest text-rose-300">
            <th class="pb-3 pr-8"><%= t(".name") %></th>
            <th class="pb-3 pr-8 hidden sm:table-cell"><%= t(".ingredients") %></th>
            <% if admin? %>
              <th class="pb-3 pr-8"><%= t(".add_remove") %></th>
              <th class="pb-3"><%= t(".actions") %></th>
            <% else %>
              <th class="pb-3"><%= t(".add_remove") %></th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% @medication.versions.each do |version| %>
            <tr class="transition-colors hover:bg-zinc-50">
              <td class="py-3 pr-8 font-medium text-zinc-800"><%= version.full_name %></td>
              <td class="py-3 pr-8 font-medium text-zinc-800 hidden sm:table-cell">
                <div class="text-xs flex items-center">
                  <ul>
                    <% version.medication_version_ingredients.each do |mvi| %>
                      <li>
                        <%= "#{format("%g", mvi.amount)}#{mvi.unit} #{mvi.active_ingredient.name} (#{format("%g", mvi.bioavailability)}F)" %>
                      </li>
                    <% end %>
                  </ul>
                  <span class="mx-1">/</span>
                  <span><%= @medication.form.name %></span>
                </div>
              </td>
              <td class="py-3 pr-4 font-medium text-zinc-800">
                <% unless Current.user.medication_versions.exists?(version.id) %>
                  <%= button_to t(".add"), prescriptions_path,
                    params: { prescription: { medication_version_id: version.id } },
                    class: "cursor-pointer px-3 py-1.5 bg-white border border-rose-300 text-rose-400 text-xs font-semibold rounded-lg hover:bg-rose-300 hover:text-white transition-colors" %>
                <% else %>
                  <%= button_to t(".remove"),
                    Current.user.prescriptions.find_by!(medication_version: version),
                    method: :delete,
                    class: "cursor-pointer px-3 py-1.5 bg-white border border-rose-300 text-rose-400 text-xs font-semibold rounded-lg hover:bg-rose-300 hover:text-white transition-colors" %>
                <% end %>
              </td>
              <% if admin? %>
                <td class="py-3 flex">
                  <%= link_to edit_medication_version_path(version), class: "mx-1" do %>
                    <%= image_tag "icons/edit.svg", class: "aspect-square h-[1.5em]" %>
                  <% end %>
                  <%= button_to medication_version_path(version), method: :delete, data: { turbo_confirm: t(".confirm_remove_version") }, class: "mx-1" do %>
                    <%= image_tag "icons/delete.svg", class: "hover:cursor-pointer aspect-square h-[1.5em]" %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if admin? %>
      <%= link_to t(".new_version"), new_medication_medication_version_path(@medication) %>
    <% end %>
  </section>
</div>
