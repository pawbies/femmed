<div class="w-full">
  <img src="/icon.svg" alt="<%= t(".logo_alt") %>" class="mx-auto aspect-square max-w-32">
  <h1 class="mt-6 text-center font-semibold text-3xl text-gray-800"><%= t(".title") %></h1>
  <h2 class="mt-3 text-center text-xl text-gray-500"><%= t(".subtitle") %></h2>

  <%= form_with url: session_url, class: "mt-10 mx-auto max-w-md" do |form| %>
    <div class="my-5">
      <%= form.label :email_address, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.email_field :email_address,
        required: true,
        autofocus: true,
        autocomplete: "username",
        placeholder: t(".email_placeholder"),
        value: params[:email_address],
        class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>
    <div class="my-5">
      <%= form.label :password, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: t(".password_placeholder"), maxlength: 72, class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>
    <div class="mt-8 flex justify-center">
      <%= form.submit t(".submit"), class: "rounded-lg px-6 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
    </div>
  <% end %>

  <% if EnvConfig::PUBLIC %>
    <div class="mt-16 flex justify-evenly items-center max-w-md mx-auto">
      <%= link_to t(".need_account"), new_user_path, class: "text-xl underline hover:no-underline" %>
    </div>
  <% end %>
</div>
