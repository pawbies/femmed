<div class="w-full">
  <h1 class="font-semibold text-center text-3xl text-gray-800"><%= t(".title", medication: @prescription.medication.name, date: @dose.taken_at.strftime("%B %e, %Y at %H:%M")) %></h1>

  <%= form_with model: [@prescription, @dose], class: "mt-10 mx-auto max-w-md",
    data: { controller: "dose-form", dose_form_ingredient_doses_per_unit_value: @prescription.medication_version.medication_version_ingredients.map { |mvi| { name: mvi.active_ingredient.name, amount: mvi.amount, unit: mvi.unit } }.to_json } do |form| %>
    <% if @dose.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6">
        <h4 class="text-red-900 font-semibold mb-2">
          <%= t(".error_count", count: @dose.errors.count) %>
        </h4>
        <ul class="list-disc list-inside text-red-800 space-y-1">
          <% @dose.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mt-5 mb-1">
      <%= form.label :amount_taken, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <div class="flex">
        <%= form.number_field :amount_taken,
          required: true,
          autofocus: true,
          step: "any",
          min: 0.001,
          data: { dose_form_target: "input", action: "dose-form#updateOutput" },
          placeholder: t(".amount_placeholder"),
          class: "shadow-sm rounded-l-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
       <span class="shadow-sm rounded-r-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-min whitespace-nowrap">
          <%= @prescription.form.name.pluralize %>
        </span>
      </div>
    </div>
    <div class="no-js:hidden ml-1 mb-3 text-sm text-rose-400 font-medium" data-dose-form-target="output"></div>

    <div class="my-5">
      <%= form.label :taken_at, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.datetime_field :taken_at,
        required: true,
        class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>

    <div class="mt-8 flex justify-center">
      <%= form.submit t(".submit"),
        class: "rounded-lg px-6 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
    </div>
  <% end %>
</div>
