<div class="w-full">
  <h1 class="font-semibold text-3xl text-center text-gray-800">New labeler</h1>

  <%= form_with model: @labeler, class: "mt-10 mx-auto max-w-md" do |form| %>
    <% if @labeler.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6">
        <h4 class="text-red-900 font-semibold mb-2">
          <%= pluralize(@labeler.errors.count, "error") %> prohibited this labeler from being saved:
        </h4>
        <ul class="list-disc list-inside text-red-800 space-y-1">
          <% @labeler.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="my-5">
      <%= form.label :name, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.text_field :name,
        placeholder: "eg. Femboy Bussy Institute",
        required: true,
        class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>

    <div class="mt-8 flex justify-center">
      <%= form.submit "Add labeler!",
        class: "rounded-lg px-6 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
    </div>
  <% end %>
</div>
