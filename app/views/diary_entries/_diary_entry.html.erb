<% is_today = diary_entry.entry_for.today? %>

<%= link_to user_diary_entry_path(@user, diary_entry), class: "block border border-gray-100 rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-shadow" do %>
  <div class="<%= is_today ? 'bg-rose-50 border-rose-100' : 'bg-gray-50 border-gray-100' %> px-5 py-3 border-b flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="<%= is_today ? 'bg-rose-400' : 'bg-gray-400' %> text-white rounded-lg px-3 py-2 text-center min-w-[60px]">
        <div class="text-2xl font-bold leading-none"><%= diary_entry.entry_for.day %></div>
        <div class="text-xs uppercase tracking-wide mt-1"><%= diary_entry.entry_for.strftime("%a") %></div>
      </div>
      <h3 class="text-sm font-semibold <%= is_today ? 'text-rose-500' : 'text-gray-500' %> uppercase tracking-wide"><%= diary_entry.entry_for.strftime("%B %e, %Y") %></h3>
    </div>
  </div>

  <div class="px-5 py-4">
    <h4 class="font-medium text-gray-900 mb-2"><%= diary_entry.title %></h4>
    <p class="text-sm text-gray-600 leading-relaxed">
      <%= truncate(diary_entry.body.to_plain_text, length: 150) %>
    </p>
    <div class="mt-4 flex items-center gap-2">
      <span class="text-xs text-gray-400"><%= diary_entry.created_at.strftime("%l:%M %p") %></span>
      <span class="text-xs text-gray-300">•</span>
      <span class="text-xs <%= is_today ? 'text-rose-400' : 'text-gray-400' %> font-medium">Personal</span>
    </div>
  </div>
<% end %>

