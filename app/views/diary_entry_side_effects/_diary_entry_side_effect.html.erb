<div class="border border-gray-100 rounded-xl bg-white hover:shadow-sm transition-shadow group">
  <div class="flex items-center justify-between px-4 py-3">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-lg bg-rose-50 flex items-center justify-center shrink-0">
        <span class="text-rose-400 text-sm">✦</span>
      </div>
      <span class="text-sm font-medium text-gray-800"><%= diary_entry_side_effect.side_effect.name %></span>
    </div>
    <div class="flex items-center gap-4">
      <div class="flex items-center gap-1.5">
        <% severity_int = DiaryEntrySideEffect.severities[diary_entry_side_effect.severity] %>
        <% 4.times do |i| %>
          <div class="rounded-full transition-all <%= i < severity_int ? 'w-2.5 h-2.5 bg-rose-400' : 'w-2 h-2 bg-gray-200' %>"></div>
        <% end %>
        <span class="text-xs text-gray-400 ml-1"><%= severity_int %>/4</span>
      </div>
      <%= button_to user_diary_entry_diary_entry_side_effect_path(@user, @diary_entry, diary_entry_side_effect),
          method: :delete,
          data: { turbo_confirm: "Remove this side effect?" },
          class: "opacity-0 group-hover:opacity-100 inline-flex items-center justify-center w-7 h-7 rounded-lg border border-zinc-200 bg-white hover:bg-rose-50 hover:border-rose-200 transition-all cursor-pointer" do %>
        <span class="text-gray-400 hover:text-rose-400 text-xs">✕</span>
      <% end %>
    </div>
  </div>

  <% if diary_entry_side_effect.notes.present? %>
    <div class="px-4 pb-3 border-t border-gray-50 pt-2 ml-11">
      <div class="text-xs text-gray-500 leading-relaxed">
        <%= diary_entry_side_effect.notes %>
      </div>
    </div>
  <% end %>
</div>
