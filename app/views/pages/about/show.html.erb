<div>
  <div class="mb-8">
    <h1 class="font-semibold text-3xl text-gray-800"><%= t(".title") %></h1>
    <p class="text-rose-400 mt-1"><%= t(".subtitle") %></p>
  </div>

  <div>
    <h2 class="font-semibold text-xl text-gray-800 mb-3"><%= t(".data_heading") %></h2>
    <p class="text-gray-600 leading-relaxed">
      <%= t(".data_body") %>
    </p>
  </div>

  <div>
    <h2 class="font-semibold text-xl text-gray-800 mb-3"><%= t(".does_heading") %></h2>
    <p class="text-gray-600 leading-relaxed">
      <%= t(".does_body") %>
    </p>
  </div>

  <div>
    <h2 class="font-semibold text-xl text-gray-800 mb-3"><%= t(".built_heading") %></h2>
    <p class="text-gray-600 leading-relaxed">
      <%= t(".built_body") %>
    </p>
  </div>

  <div>
    <h2 class="font-semibold text-xl text-gray-800 mb-4"><%= t(".thanks_heading") %></h2>
    <div class="flex flex-col gap-3 xl:mx-auto">
      <a href="https://github.com/dooklin" target="_blank"
        class="flex items-center gap-4 bg-white border border-rose-200 rounded-xl px-4 py-3 shadow-sm hover:shadow-md hover:border-rose-300 transition-all group">
        <img src="https://github.com/dooklin.png" alt="dooklin" class="w-10 h-10 rounded-full border border-rose-100">
        <div>
          <p class="font-medium text-gray-800 group-hover:text-rose-500 transition-colors">Dooklin</p>
          <p class="text-xs text-gray-400">@dooklin</p>
        </div>
        <span class="ml-auto text-rose-300 group-hover:text-rose-400 transition-colors">↗</span>
      </a>
      <a href="https://github.com/Alexander-Metzger" target="_blank"
        class="flex items-center gap-4 bg-white border border-rose-200 rounded-xl px-4 py-3 shadow-sm hover:shadow-md hover:border-rose-300 transition-all group">
        <img src="https://github.com/Alexander-Metzger.png" alt="dooklin" class="w-10 h-10 rounded-full border border-rose-100">
        <div>
          <p class="font-medium text-gray-800 group-hover:text-rose-500 transition-colors">Alexander Metzger</p>
          <p class="text-xs text-gray-400">@Alexander-Metzger</p>
        </div>
        <span class="ml-auto text-rose-300 group-hover:text-rose-400 transition-colors">↗</span>
      </a>
    </div>
  </div>
</div>
