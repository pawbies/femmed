<div class="w-full space-y-8">
  <section data-controller="live-search">
    <div class="relative">
      <%= form_with url: search_path, class: "flex gap-2", method: :get do |form| %>
        <%= form.text_field :query,
          placeholder: t(".search_placeholder"),
          data: { action: "input->live-search#search", live_search_target: "input" },
          class: "shadow-sm rounded-xl border bg-white border-rose-200 px-4 py-3 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-rose-300 transition" %>
        <%= form.submit t(".yippie"), class: "rounded-xl px-6 py-3 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold shadow-sm transition-colors" %>
      <% end %>
      <div id="search_results" class="absolute max-h-96 overflow-y-auto top-full left-0 right-0 z-50 mt-2 rounded-xl shadow-lg bg-white border border-rose-100"></div>
    </div>
  </section>

  <section class="flex items-stretch gap-3">
    <%= link_to prescriptions_path, class: "group w-2/3 h-36 rounded-2xl bg-white border border-rose-200 shadow-sm hover:shadow-md hover:border-rose-300 hover:-translate-y-0.5 transition flex gap-2 flex-col justify-center items-center" do %>
      <%= image_tag "icons/medicine.svg", class: "h-12 w-12 transition group-hover:scale-105" %>
      <span class="font-medium text-gray-700"><%= t(".my_prescriptions") %></span>
    <% end %>
    <%= link_to developments_path, class: "group w-1/3 h-36 rounded-2xl bg-white border border-rose-200 shadow-sm hover:shadow-md hover:border-rose-300 hover:-translate-y-0.5 transition flex gap-2 flex-col justify-center items-center p-3" do %>
      <%= image_tag "icons/blood.svg", class: "h-12 w-12 transition group-hover:scale-105" %>
      <span class="text-center text-sm font-medium text-gray-700"><%= t(".track_health_data") %></span>
    <% end %>
  </section>

  <section>
    <h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8">
      <%= t(".views") %>
    </h3>

    <div class="grid grid-cols-4 gap-3">
      <%= link_to timeline_path, class: "group aspect-square rounded-2xl bg-white border border-rose-200 shadow-sm hover:shadow-md hover:border-rose-300 hover:-translate-y-0.5 transition p-3 flex gap-2 flex-col justify-center items-center" do %>
        <%= image_tag "icons/timeline.svg", class: "h-10 w-10 transition group-hover:scale-105" %>
        <h4 class="text-center text-sm font-medium text-gray-700"><%= t(".timeline") %></h4>
      <% end %>
      <%= link_to calendar_path, class: "group aspect-square rounded-2xl bg-white border border-rose-200 shadow-sm hover:shadow-md hover:border-rose-300 hover:-translate-y-0.5 transition p-3 flex gap-2 flex-col justify-center items-center" do %>
        <%= image_tag "icons/calendar.svg", class: "h-10 w-10 transition group-hover:scale-105" %>
        <h4 class="text-center text-sm font-medium text-gray-700"><%= t(".calendar") %></h4>
      <% end %>
      <% if admin? %>
        <%= link_to admin_path, class: "group aspect-square rounded-2xl bg-white border border-rose-200 shadow-sm hover:shadow-md hover:border-rose-300 hover:-translate-y-0.5 transition p-3 flex gap-2 flex-col justify-center items-center" do %>
          <%= image_tag "icons/management.svg", class: "h-10 w-10 transition group-hover:scale-105" %>
          <h4 class="text-center text-sm font-medium text-gray-700"><%= t(".management") %></h4>
        <% end %>
      <% end %>
      <%= link_to Current.user, class: "group aspect-square rounded-2xl bg-white border border-rose-200 shadow-sm hover:shadow-md hover:border-rose-300 hover:-translate-y-0.5 transition p-3 flex gap-2 flex-col justify-center items-center" do %>
        <%= image_tag "icons/user.svg", class: "h-10 w-10 transition group-hover:scale-105" %>
        <h4 class="text-center text-sm font-medium text-gray-700"><%= t(".your_profile") %></h4>
      <% end %>
    </div>
  </section>

  <% if @concentrations.any? %>
    <section class="mb-6 w-full">
      <h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8">
        <%= t(".current_concentrations") %>
      </h3>

      <div class="bg-white border border-rose-200 rounded-xl overflow-x-auto shadow-sm">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-rose-50 text-left text-xs uppercase tracking-widest text-rose-400">
              <th class="px-5 py-3 font-semibold"><%= t(".ingredient") %></th>
              <th class="px-5 py-3 font-semibold"><%= t(".concentration") %></th>
              <th class="px-5 py-3 font-semibold"><%= t(".trend") %></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-zinc-100">
            <% @concentrations.each do |entry| %>
              <tr class="transition-colors hover:bg-rose-50/30">
                <td class="px-5 py-3.5 text-nowrap font-medium text-zinc-800">
                  <%= link_to entry[:name], active_ingredient_path(id: entry[:id]) %>
                </td>
                <td class="px-5 py-3.5 text-nowrap font-mono text-zinc-700">
                  <%= number_with_precision(entry[:concentration], precision: 4) %> mg/L
                </td>
                <td class="px-5 py-3.5 text-nowrap font-mono <%= entry[:rate] >= 0 ? 'text-emerald-600' : 'text-rose-500' %>">
                  <%= entry[:rate] >= 0 ? "▲" : "▼" %>
                  <%= number_with_precision(entry[:rate].abs, precision: 4) %> mg/L/h
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
</div>
