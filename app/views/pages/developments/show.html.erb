<% content_for(:title, t(".title")) %>

<div class="w-full">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8 md:w-3/5 mx-auto">
    <%= link_to "#", class: "group border border-rose-200 rounded-2xl p-8 hover:bg-rose-50 hover:border-rose-300 transition-all shadow-sm" do %>
      <div class="flex flex-col items-center text-center gap-4">
        <div class="w-14 h-14 rounded-full bg-rose-100 text-rose-400 flex items-center justify-center group-hover:bg-rose-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3v2.25M14.25 3v2.25M3.75 9.75h16.5M5.25 5.25h13.5a1.5 1.5 0 011.5 1.5v12a1.5 1.5 0 01-1.5 1.5H5.25a1.5 1.5 0 01-1.5-1.5v-12a1.5 1.5 0 011.5-1.5z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 13.5v3M10.5 15h3" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-gray-800 group-hover:text-rose-500 transition-colors"><%= t(".biomarkers") %></h2>
          <p class="text-sm text-gray-400 mt-1"><%= t(".biomarkers_desc") %></p>
        </div>
      </div>
    <% end %>

    <%= link_to blood_pressure_readings_path, class: "group border border-rose-200 rounded-2xl p-8 hover:bg-rose-50 hover:border-rose-300 transition-all shadow-sm" do %>
      <div class="flex flex-col items-center text-center gap-4">
        <div class="w-14 h-14 rounded-full bg-rose-100 text-rose-400 flex items-center justify-center group-hover:bg-rose-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
          </svg>
        </div>
        <div>
          <h2 class="text-lg font-semibold text-gray-800 group-hover:text-rose-500 transition-colors"><%= t(".blood_pressure") %></h2>
          <p class="text-sm text-gray-400 mt-1"><%= t(".blood_pressure_desc") %></p>
        </div>
      </div>
    <% end %>
  </div>
</div>
