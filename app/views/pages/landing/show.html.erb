<% content_for(:title, t(".title")) %>

<div class="w-full">
  <img src="/icon.svg" alt="<%= t(".logo_alt") %>" class="mx-auto aspect-square max-w-64">

  <h1 class="mt-6 text-center font-semibold text-3xl text-gray-800">
    <%= t(".title") %>
  </h1>
  <h2 class="mt-3 text-center text-xl text-gray-500">
    <%= t(".subtitle") %>
  </h2>

  <div class="mt-16 mx-auto md:max-w-2/3 flex justify-evenly items-center">
    <% if EnvConfig::PUBLIC %>
      <%= link_to t(".get_started"), new_user_path, class: "text-xl underline hover:no-underline" %>
      <%= link_to t(".already_signed_up"), new_session_path, class: "text-xl underline hover:no-underline" %>
    <% else %>
        <%= link_to t(".login"), new_session_path, class: "text-xl underline hover:no-underline" %>
    <% end %>
  </div>
</div>
