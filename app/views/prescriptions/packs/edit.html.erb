<div class="w-full">
  <h1 class="font-semibold text-center text-3xl text-gray-800"><%= t(".title", prescription: @prescription.full_name) %></h1>

  <%= form_with model: @pack, url: prescription_pack_path(@prescription, @pack), class: "mt-10 mx-auto max-w-md" do |form| %>
    <% if @pack.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6">
        <h4 class="text-red-900 font-semibold mb-2">
          <%= t(".error_count", count: @pack.errors.count) %>
        </h4>
        <ul class="list-disc list-inside text-red-800 space-y-1">
          <% @pack.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>


    <div class="my-5">
      <%= form.label :amount, t(".amount_label", form: @prescription.form.name.pluralize), class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <div class="flex items-center">
        <%= form.number_field :amount,
          required: true,
          autofocus: true,
          min: 1,
          placeholder: ":3",
          class: "shadow-sm rounded-l-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
        <span class="shadow-sm rounded-r-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-min whitespace-nowrap">
          <%= @prescription.form.name.pluralize %>
        </span>
      </div>
    </div>

    <div class="my-5">
      <%= form.label :acquired_at, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.date_field :acquired_at,
        required: true,
        class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
    </div>

    <div class="mt-8 flex justify-center">
      <%= form.submit t(".submit"),
        class: "rounded-lg px-6 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
    </div>
  <% end %>
</div>
