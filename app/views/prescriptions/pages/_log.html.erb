<% doses = @prescription.doses.order(taken_at: :desc).to_a %>
<h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8">
  Log
  <span class="text-gray-400 font-normal italic">
    - <%= "#{doses.size} #{'time'.pluralize(doses.size)}" %>
    taken already
  </span>
</h3>

<table class="w-full mt-6 text-sm border-collapse">
  <thead>
    <tr class="border-b border-zinc-200 text-left text-xs uppercase tracking-widest text-rose-300">
      <th class="pb-3 pr-8">Dose</th>
      <th class="pb-3 pr-8">Time</th>
      <% if @prescription.active? %>
        <th class="pb-3 pr-8">Date</th>
        <th class="pb-3">Edit</th>
      <% else %>
        <th class="pb-3">Date</th>
      <% end %>
    </tr>
  </thead>
  <tbody class="divide-y divide-zinc-100">
    <% doses.each do |dose| %>
      <tr class="transition-colors hover:bg-zinc-50" id="<%= dom_id(dose) %>">
        <td class="py-3 pr-8 font-medium text-zinc-800">
          <%= "#{format("%g", dose.amount_taken)} #{@prescription.form.name.pluralize(dose.amount_taken)}" %>
        </td>
        <td class="py-3 pr-8 font-medium text-zinc-800">
          <%= local_time(dose.taken_at, "%H:%M") %>
        </td>
        <td class="my-3 font-medium text-zinc-800">
          <%= local_time(dose.taken_at, "%B %e, %Y") %>
        </td>
        <% if @prescription.active? %>
          <td>
            <div class="flex">
              <%= link_to edit_prescription_dose_path(@prescription, dose), target: "_top", class: "mx-1" do %>
              <%= image_tag "icons/edit.svg", class: "aspect-square h-[1.5em]" %>
              <% end %>
              <%= button_to prescription_dose_path(@prescription, dose), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: "mx-1" do %>
                <%= image_tag "icons/delete.svg", class: "hover:cursor-pointer aspect-square h-[1.5em]" %>
              <% end %>
            </div>
          </td>
        <% end %>
      </tr>
    <% end %>
  </tbody>
</table>
<%= render "partials/add_button", path: new_prescription_dose_path(@prescription) %>
