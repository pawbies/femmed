<h1 class="text-2xl font-semibold">Settings</h1>
<section class="mt-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-rose-400 mb-4">General</h2>
  <div class="rounded-xl border border-zinc-200 bg-white p-6">
    <%= form_with model: [ @user, @prescription ], data: { turbo_frame: "_top" } do |form| %>
      <%= form.label :amount, "Planned amount per dose", class: "block text-sm font-medium text-gray-700 my-2" %>
      <div class="flex">
        <%= form.number_field :amount,
          min: 0,
          required: true,
          step: "any",
          class: "shadow-sm rounded-l-md border bg-rose-50 border-rose-300 px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
        <span class="shadow-sm rounded-r-md border border-l-0 bg-rose-50 border-rose-300 px-3 py-2 text-gray-500 text-sm whitespace-nowrap">
          <%= @prescription.medication_version.form.name.pluralize %>
        </span>
      </div>

      <%= form.label :preview_past, "Preview into the past", class: "block text-sm font-medium text-gray-700 my-2" %>
      <div class="flex">
        <%= form.number_field :preview_past,
          min: 0,
          required: true,
          step: "any",
          class: "shadow-sm rounded-l-md border bg-rose-50 border-rose-300 px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
        <span class="shadow-sm rounded-r-md border border-l-0 bg-rose-50 border-rose-300 px-3 py-2 text-gray-500 text-sm whitespace-nowrap">
          Hours
        </span>
      </div>


      <%= form.label :preview_future, "Preview into the future", class: "block text-sm font-medium text-gray-700 my-2" %>
      <div class="flex">
        <%= form.number_field :preview_future,
          required: true,
          step: "any",
          class: "shadow-sm rounded-l-md border bg-rose-50 border-rose-300 px-3 py-2 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
        <span class="shadow-sm rounded-r-md border border-l-0 bg-rose-50 border-rose-300 px-3 py-2 text-gray-500 text-sm whitespace-nowrap">
          Hours
        </span>
      </div>


      <div class="flex items-center justify-between mt-5 pt-4 border-t border-zinc-100">
        <div>
          <%= form.label :active, "Active prescription", class: "block text-sm font-medium text-gray-700" %>
          <p class="text-xs text-gray-400 mt-0.5">Enables dose tracking and reminders</p>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <%= form.check_box :active, class: "sr-only peer" %>
          <div class="w-11 h-6 bg-zinc-200 rounded-full peer
                      peer-checked:bg-rose-400
                      peer-focus:ring-2 peer-focus:ring-rose-300
                      after:content-[''] after:absolute after:top-0.5 after:left-0.5
                      after:bg-white after:rounded-full after:h-5 after:w-5
                      after:transition-all after:shadow-sm
                      peer-checked:after:translate-x-5
                      transition-colors duration-200">
          </div>
        </label>
      </div>

      <div class="mt-5 pt-4 border-t border-zinc-100 flex justify-end">
        <%= form.submit "Save changes", class: "rounded-md px-5 py-2 bg-rose-400 hover:bg-rose-300 cursor-pointer font-medium transition-colors" %>
      </div>
    <% end %>
  </div>
</section>
<section class="mt-8">
  <h2 class="text-xs font-semibold uppercase tracking-widest text-red-400 mb-4">Danger Zone</h2>
  <div class="rounded-xl border border-red-200 bg-red-50 p-6 flex items-center justify-between gap-6">
    <div>
      <p class="font-medium text-red-700">Remove this prescription</p>
      <p class="text-sm text-red-400 mt-0.5">This will permanently delete all doses and packs associated with it.</p>
    </div>
    <%= button_to "Remove prescription", user_prescription_path(@user, @prescription),
      method: :delete,
      data: { turbo_confirm: "Are you sure?", turbo_frame: "_top" },
      class: "shrink-0 rounded-md px-4 py-2 bg-white border border-red-300 text-red-500 hover:bg-red-500 hover:text-white hover:border-red-500 font-medium text-sm transition-colors cursor-pointer" %>
  </div>
</section>
