<div class="flex justify-between items-center pb-3 border-b border-rose-100 mb-8">
  <h3 class="text-2xl font-semibold text-gray-700">
    <%= t(".title") %>
  </h3>

  <% unless @prescription.routine.present? %>
    <%= link_to t(".set_routine"), new_prescription_routine_path(@prescription), target: "_top", class: "rounded-lg px-6 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
  <% end %>
</div>

<% if @prescription.routine.present? %>
    <div class="rounded-lg border border-zinc-300 p-4">
      <p class="text-xs uppercase tracking-widest text-rose-300 mb-2"><%= t(".schedule") %></p>
      <p class="text-xl font-bold text-gray-900"><%= @prescription.routine.to_s.capitalize %></p>
      <p class="text-xs text-gray-500 mt-1"><%= t(".starting") %> <%= @prescription.routine.start_time.strftime("%-d %B %Y") %></p>
    </div>

    <div class="flex gap-3 mt-6">
      <%= link_to t(".edit_routine"),
        edit_prescription_routine_path(@prescription),
        target: "_top",
        class: "rounded-md px-4 py-2 text-sm font-medium border border-zinc-200 text-gray-600 hover:bg-zinc-50 transition-colors" %>
      <%= button_to t(".remove_routine"),
        prescription_routine_path(@prescription),
        method: :delete,
        target: "_top",
        class: "rounded-md px-4 py-2 text-sm font-medium border border-zinc-200 text-gray-600 hover:bg-zinc-50 transition-colors cursor-pointer" %>
    </div>
  </section>

  <% upcoming = @prescription.routine.next_occurrences(7) rescue [] %>
  <% if upcoming.any? %>
    <section class="mt-12">
      <h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8"><%= t(".upcoming") %></h3>

      <table class="w-full mt-3 text-sm">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-xs uppercase tracking-widest text-rose-300">
            <th class="pb-3 pr-8"><%= t(".day") %></th>
            <th class="pb-3 pr-8"><%= t(".date") %></th>
            <th class="pb-3"><%= t(".time") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% upcoming.each do |occurrence| %>
            <tr class="transition-colors hover:bg-zinc-50">
              <td class="py-3 pr-8 font-medium text-zinc-800"><%= occurrence.strftime("%A") %></td>
              <td class="py-3 pr-8 font-medium text-zinc-800"><%= occurrence.strftime("%-d %B %Y") %></td>
              <td class="py-3 font-medium text-zinc-800"><%= occurrence.strftime("%H:%M") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </section>
  <% end %>
<% else %>
  <p class="text-xl text-center"><%= t(".no_routine") %></p>
<% end %>
