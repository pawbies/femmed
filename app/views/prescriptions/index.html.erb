<% content_for(:title, t(".title")) %>

<div class="w-full">
  <% if @prescriptions.any? %>
    <div class="mx-2 mt-4 grid grid-cols-1 md:grid-cols-2 gap-3">
      <%= render partial: "prescriptions/prescription", collection: @prescriptions %>
    </div>
  <% else %>
    <div class="mx-2 mt-8 flex flex-col items-center justify-center rounded-2xl border border-dashed border-rose-200 bg-rose-50/50 px-6 py-14 text-center">
      <div class="flex h-14 w-14 items-center justify-center rounded-full bg-rose-100 text-rose-400">
        <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
      </div>
      <h3 class="mt-4 text-lg font-semibold text-gray-800"><%= t(".empty_title") %></h3>
      <p class="mt-1 max-w-sm text-sm text-gray-500"><%= t(".empty_body") %></p>
      <%= link_to search_path, class: "mt-6 inline-flex items-center gap-2 rounded-lg bg-rose-400 hover:bg-rose-500 px-5 py-2.5 text-white font-semibold shadow-sm transition-colors" do %>
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M11 19a8 8 0 100-16 8 8 0 000 16z"/>
        </svg>
        <%= t(".empty_cta") %>
      <% end %>
    </div>
  <% end %>
</div>
