<% content_for(:title, @prescription.full_name) %>

<div class="w-full">
  <h1 class="text-3xl font-semibold text-gray-800"><%= @prescription.medication_version.full_name %></h1>

  <turbo-frame id="prescriptions_page">
    <%= render "nav" %>

    <h1 class="text-2xl font-semibold text-gray-800 pb-3 border-b border-rose-100 mb-8"><%= t(".title") %></h1>
    <section class="mt-8">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-rose-400 mb-4"><%= t(".general") %></h2>
      <div class="rounded-xl border border-zinc-200 bg-white p-6">
        <%= form_with model: @prescription, data: { turbo_frame: "_top" } do |form| %>
          <%= form.label :amount, t(".planned_amount"), class: "block text-sm font-medium text-gray-700 my-2" %>
          <div class="flex">
            <%= form.number_field :amount,
              min: 0.001,
              required: true,
              step: "any",
              class: "shadow-sm rounded-l-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
            <span class="shadow-sm rounded-r-lg border border-l-0 bg-rose-50 border-rose-300 px-4 py-2.5 text-gray-500 text-sm whitespace-nowrap">
              <%= @prescription.medication_version.form.name.pluralize %>
            </span>
          </div>

          <%= form.label :preview_past, t(".preview_past"), class: "block text-sm font-medium text-gray-700 my-2" %>
          <div class="flex">
            <%= form.number_field :preview_past,
              min: 0,
              required: true,
              step: "any",
              class: "shadow-sm rounded-l-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
            <span class="shadow-sm rounded-r-lg border border-l-0 bg-rose-50 border-rose-300 px-4 py-2.5 text-gray-500 text-sm whitespace-nowrap">
              <%= t(".hours") %>
            </span>
          </div>


          <%= form.label :preview_future, t(".preview_future"), class: "block text-sm font-medium text-gray-700 my-2" %>
          <div class="flex">
            <%= form.number_field :preview_future,
              required: true,
              step: "any",
              class: "shadow-sm rounded-l-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full focus:outline-none focus:ring-2 focus:ring-rose-300" %>
            <span class="shadow-sm rounded-r-lg border border-l-0 bg-rose-50 border-rose-300 px-4 py-2.5 text-gray-500 text-sm whitespace-nowrap">
              <%= t(".hours") %>
            </span>
          </div>

          <div class="flex items-center justify-between mt-5 pt-4 border-t border-zinc-100">
            <div>
              <%= form.label :pack_tracking_enabled, t(".enable_pack_tracking"), class: "block text-sm font-medium text-gray-700" %>
              <p class="text-xs text-gray-400 mt-0.5"><%= t(".pack_tracking_desc") %></p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <%= form.check_box :pack_tracking_enabled, class: "sr-only peer" %>
              <div class="w-11 h-6 bg-zinc-200 rounded-full peer
                          peer-checked:bg-rose-400
                          peer-focus:ring-2 peer-focus:ring-rose-300
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:bg-white after:rounded-full after:h-5 after:w-5
                          after:transition-all after:shadow-sm
                          peer-checked:after:translate-x-5
                          transition-colors duration-200">
              </div>
            </label>
          </div>


          <div class="flex items-center justify-between mt-5 pt-4 border-t border-zinc-100">
            <div>
              <%= form.label :active, t(".active_prescription"), class: "block text-sm font-medium text-gray-700" %>
              <p class="text-xs text-gray-400 mt-0.5"><%= t(".active_prescription_desc") %></p>
            </div>
            <label class="relative inline-flex items-center cursor-pointer">
              <%= form.check_box :active, class: "sr-only peer" %>
              <div class="w-11 h-6 bg-zinc-200 rounded-full peer
                          peer-checked:bg-rose-400
                          peer-focus:ring-2 peer-focus:ring-rose-300
                          after:content-[''] after:absolute after:top-0.5 after:left-0.5
                          after:bg-white after:rounded-full after:h-5 after:w-5
                          after:transition-all after:shadow-sm
                          peer-checked:after:translate-x-5
                          transition-colors duration-200">
              </div>
            </label>
          </div>

          <div class="mt-5 pt-4 border-t border-zinc-100 flex justify-end">
            <%= form.submit t(".save"), class: "rounded-lg px-5 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
          </div>
        <% end %>
      </div>
    </section>
    <section class="mt-8">
      <h2 class="text-xs font-semibold uppercase tracking-widest text-red-400 mb-4"><%= t(".danger_zone") %></h2>
      <div class="rounded-xl border border-red-200 bg-red-50 p-6 flex items-center justify-between gap-6">
        <div>
          <p class="font-medium text-red-700"><%= t(".remove_label") %></p>
          <p class="text-sm text-red-400 mt-0.5"><%= t(".remove_desc") %></p>
        </div>
        <%= button_to t(".remove_button"), @prescription,
          method: :delete,
          data: { turbo_confirm: t(".confirm_remove"), turbo_frame: "_top" },
          class: "shrink-0 rounded-md px-4 py-2 bg-white border border-red-300 text-red-500 hover:bg-red-500 hover:text-white hover:border-red-500 font-medium text-sm transition-colors cursor-pointer" %>
      </div>
    </section>

  </turbo-frame>
</div>
