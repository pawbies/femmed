<div class="w-full">
  <h1 class="text-3xl font-semibold text-gray-800"><%= @prescription.medication.name %></h1>

  <turbo-frame id="prescriptions_page">
    <%= render "prescriptions/nav" %>

    <h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8">
      <%= t(".title") %>
    </h3>

    <div>
      <h4 class="font-medium text-lg"><%= @prescription.medication.name %></h4>
      <p class="text-md text-gray-400 mb-3 italic">
        <%= @prescription.medication.form.name %>
        <% if @prescription.medication.labeler.present? %>
          &middot;
          <%= @prescription.medication.labeler.name %>
        <% end %>
      </p>
    </div>

    <% if @prescription.medication.notes.present? %>
      <div class="prose prose-sm max-w-none text-gray-700">
        <%= @prescription.medication.notes %>
      </div>
    <% end %>

    <div class="mt-12">
      <h3 class="text-xs font-semibold tracking-widest uppercase text-rose-400 mb-3"><%= t(".your_version") %></h3>
      <p class="text-gray-800 font-medium">
        <%= @prescription.medication.name %> <%= @prescription.medication_version.added_name %>
      </p>
      <% ingredients = @prescription.medication_version.medication_version_ingredients %>
      <% if ingredients.any? %>
        <ul class="mt-2 space-y-1">
          <% ingredients.each do |mvi| %>
            <li class="text-sm text-gray-600">
              <%= mvi.active_ingredient.name %> &mdash;
              <span class="font-medium"><%= format("%g", mvi.amount) %><%= mvi.unit %></span>
              <span>
                (F <%= format("%g", mvi.bioavailability) %> &rarr; <%= format("%g", mvi.amount * mvi.bioavailability) %><%= mvi.unit %>)
              </span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <div class="mt-6">
      <%= render "medications/preview_graph", medication_version: @prescription.medication_version %>
    </div>

    <% if @prescription.medication.categories.any? %>
      <div class="mt-12">
        <h3 class="text-xs font-semibold tracking-widest uppercase text-rose-400 mb-3"><%= t(".categories") %></h3>
        <div class="flex flex-wrap gap-2">
          <%= render partial: "categories/category", collection: @prescription.medication.categories %>
        </div>
      </div>
    <% end %>
  </turbo-frame>
</div>
