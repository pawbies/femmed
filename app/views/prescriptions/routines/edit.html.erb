<% content_for(:title, t(".title", prescription: @prescription.full_name)) %>

<div class="w-full">
  <h1 class="font-semibold text-center text-3xl text-gray-800"><%= t(".title", prescription: @prescription.full_name) %></h1>

  <div class="mt-10 mx-auto max-w-md">
    <%= render "form",
      url: prescription_routine_path(@prescription),
      method: :patch,
      submit_label: t(".submit"),
      routine_data: @routine_data %>
  </div>
</div>
