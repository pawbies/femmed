<div class="w-full">
  <h1 class="text-3xl font-semibold text-gray-800"><%= @prescription.medication_version.full_name %></h1>

  <turbo-frame id="prescriptions_page">
    <nav class="mt-8 mb-12 flex gap-8 border-b border-gray-200 overflow-x-scroll">
      <%= link_to t(".log"), prescription_path(@prescription, page: "Log"),
          class: "pb-3 font-medium text-gray-600 hover:text-gray-900 transition-colors #{
            params[:page].nil? || params[:page] == 'Log' ? 'border-b-2 border-rose-500 text-rose-600' : ''
          }" %>

      <% if @prescription.pack_tracking_enabled? %>
        <%= link_to t(".packs"), prescription_path(@prescription, page: "Packs"),
            class: "pb-3 font-medium text-gray-600 hover:text-gray-900 transition-colors #{
              params[:page] == 'Packs' ? 'border-b-2 border-rose-500 text-rose-600' : ''
            }" %>
      <% end %>

      <%= link_to t(".routine"), prescription_path(@prescription, page: "Routine"),
          class: "pb-3 font-medium text-gray-600 hover:text-gray-900 transition-colors #{
            params[:page] == 'Routine' ? 'border-b-2 border-rose-500 text-rose-600' : ''
          }" %>

      <%= link_to t(".about"), prescription_path(@prescription, page: "About"),
          class: "pb-3 font-medium text-gray-600 hover:text-gray-900 transition-colors #{
            params[:page] == 'About' ? 'border-b-2 border-rose-500 text-rose-600' : ''
          }" %>

      <%= link_to t(".settings"), prescription_path(@prescription, page: "Settings"),
          class: "pb-3 font-medium text-gray-600 hover:text-gray-900 transition-colors #{
            params[:page] == 'Settings' ? 'border-b-2 border-rose-500 text-rose-600' : ''
          }" %>
    </nav>

    <% if params[:page] == "Log" %>
      <%= render "prescriptions/pages/log" %>
    <% elsif params[:page] == "Packs" %>
      <%= render "prescriptions/pages/packs" %>
    <% elsif params[:page] == "Routine" %>
      <%= render "prescriptions/pages/routine" %>
    <% elsif params[:page] == "About" %>
        <%= render "prescriptions/pages/about" %>
    <% elsif params[:page] == "Settings" %>
      <%= render "prescriptions/pages/settings" %>
    <% else %>
      <%= render "prescriptions/pages/log" %>
    <% end %>
  </turbo-frame>
</div>
