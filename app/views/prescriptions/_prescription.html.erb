<%= link_to user_prescription_path(Current.user, prescription) do %>
  <%
    mvis = prescription.medication_version.medication_version_ingredients
    unsupported = mvis.select { |m| !%w[mg g mcg].include?(m.unit) }.map do |m|
      "#{m.active_ingredient.name} (#{m.unit})"
    end
    incomplete_pk = prescription.medication_version.medication.active_ingredients.select do |i|
      i.half_life.blank? || i.absorption_rate.blank? || i.volume_of_distribution.blank?
    end.map(&:name)
  %>
  <div class="no-js:hidden w-full bg-white border border-rose-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow <%= 'opacity-60 border-zinc-300' unless prescription.active? %>"
       data-controller="prescriptions-preview"
      data-prescriptions-preview-past-value="<%= prescription.preview_past %>"
      data-prescriptions-preview-future-value="<%= prescription.preview_future %>"
      data-prescriptions-preview-release-profile-value="<%=
      {
        name: prescription.medication.release_profile&.name || "Immediate",
        delay: prescription.medication.medication_release_profile.delay,
        release_duration: prescription.medication.medication_release_profile.release_duration
      }.compact.to_json %>"

      data-prescriptions-preview-ingredients-value="<%=
        prescription.medication_version.medication.active_ingredients.map do |ingredient|
          mvi = prescription.medication_version.medication_version_ingredients
            .find { |m| m.active_ingredient_id == ingredient.id }
          next if ingredient.half_life.blank? || ingredient.absorption_rate.blank? || ingredient.volume_of_distribution.blank?
          multiplier = case mvi&.unit
                       when "mg"  then 1.0
                       when "g"   then 0.001
                       when "mcg" then 1000.0
                       else nil
                       end
          doses = if multiplier
            prescription.doses.where(taken_at: 1.week.ago..).map do |dose|
              { takenAt: dose.taken_at.to_i, amount: dose.amount_taken * mvi.amount * multiplier }
            end
          else
            []
          end
          { name: ingredient.name, halfLife: ingredient.half_life, doses: doses, absorptionRate: ingredient.absorption_rate, volumeOfDistribution: ingredient.volume_of_distribution }
        end.compact.to_json
      %>">
    <div class="no-js:hidden">
      <div class="px-4 pt-4 pb-2 flex items-center justify-between">
        <div>
          <h5 class="font-semibold text-gray-800"><%= prescription.medication_version.full_name %></h5>
          <p class="text-xs text-rose-400 mt-0.5">Plasma concentration over 48h</p>
        </div>
        <span class="text-xs <%= prescription.active? ? 'bg-rose-100 text-rose-500' : 'bg-zinc-100 text-zinc-400' %> font-medium px-2 py-1 rounded-full">
          <%= prescription.active? ? 'Active' : 'Inactive' %>
        </span>
      </div>
      <div data-prescriptions-preview-target="chart" class="w-full"></div>
      <div class="px-4 py-2 border-t border-rose-100 flex flex-col gap-1 pb-6">
        <% if unsupported.any? %>
          <p class="text-xs text-amber-400">
            ⚠ <%= unsupported.to_sentence %> excluded — unit not supported for PK calculation
          </p>
        <% end %>
        <% if incomplete_pk.any? %>
          <p class="text-xs text-amber-400">
            ⚠ <%= incomplete_pk.to_sentence %> excluded — missing half-life, absorption rate, or Vd
          </p>
        <% end %>
      </div>
    </div>
    <div class="js:hidden px-4 py-4 flex items-center justify-between">
      <div>
        <h5 class="font-semibold text-gray-800"><%= prescription.medication_version.full_name %></h5>
        <p class="text-xs text-rose-400 mt-0.5">
          <%= prescription.medication_version.medication.active_ingredients.map(&:name).to_sentence %>
        </p>
      </div>
      <span class="text-xs <%= prescription.active? ? 'bg-rose-100 text-rose-500' : 'bg-zinc-100 text-zinc-400' %> font-medium px-2 py-1 rounded-full">
        <%= prescription.active? ? 'Active' : 'Inactive' %>
      </span>
    </div>
  </div>
  <div class="js:hidden w-full bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow border <%= prescription.active? ? 'border-rose-200' : 'border-zinc-300 opacity-60' %>">
    <div class="px-4 py-4 flex items-center justify-between">
      <div>
        <h5 class="font-semibold text-gray-800"><%= prescription.medication_version.full_name %></h5>
        <p class="text-xs text-rose-400 mt-0.5">
          <%= prescription.medication_version.medication.active_ingredients.map(&:name).to_sentence %>
        </p>
      </div>
      <span class="text-xs <%= prescription.active? ? 'bg-rose-100 text-rose-500' : 'bg-zinc-100 text-zinc-400' %> font-medium px-2 py-1 rounded-full">
        <%= prescription.active? ? 'Active' : 'Inactive' %>
      </span>
    </div>
  </div>
<% end %>
