<% minimal = local_assigns.fetch(:minimal, false) %>

<% unless minimal || prescription.medication_version_ingredients.pk_compatible.none? %>
  <%= link_to prescription_doses_path(prescription),
    class: "w-full bg-white border border-rose-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow #{'opacity-60 border-zinc-300' unless prescription.active?}",
    data: {
      controller: "prescriptions-preview",
      prescriptions_preview_past_value: prescription.preview_past,
      prescriptions_preview_future_value: prescription.preview_future,
      prescriptions_preview_plot_value: PkCalculator.for_prescription(prescription).to_json,
      prescriptions_preview_xlabel_value: t(".x_label"),
      prescriptions_preview_ylabel_value: t(".y_label"),
      prescriptions_preview_nowlabel_value: t(".now_label")
    } do %>
      <div class="<%= "hidden" unless prescription.active? %> no-js:hidden">
        <div class="px-4 pt-4 pb-2 flex items-center justify-between">
          <div>
            <h5 class="font-semibold text-gray-800"><%= prescription.medication_version.full_name %></h5>
            <p class="text-xs text-rose-400 mt-0.5">
              <%= t(".plasma_concentration", hours: format("%g", prescription.preview_future + prescription.preview_past)) %>
            </p>
          </div>
          <span class="text-xs <%= prescription.active? ? 'bg-rose-100 text-rose-500' : 'bg-zinc-100 text-zinc-400' %> font-medium px-2 py-1 rounded-full">
            <%= prescription.active? ? t(".active") : t(".inactive") %>
          </span>
        </div>
        <div data-prescriptions-preview-target="chart" class="w-full"></div>
        <div class="px-4 py-2 border-t border-rose-100 flex flex-col gap-1 pb-6">
          <% incompatible = prescription.medication_version.medication_version_ingredients.pk_incompatible %>
          <% if incompatible.any? %>
            <p class="text-xs text-amber-800">
              ⚠ <%= t(".pk_excluded", ingredients: incompatible.map { |mvi| mvi.active_ingredient.name }.to_sentence) %>
            </p>
          <% end %>
        </div>
      </div>


      <div class="<%= "hidden" if prescription.active? %> px-4 py-4 flex items-center justify-between">
        <div>
          <h5 class="font-semibold text-gray-800"><%= prescription.medication_version.full_name %></h5>
          <p class="text-xs text-rose-400 mt-0.5">
            <%= prescription.medication_version.medication.active_ingredients.map(&:name).to_sentence %>
          </p>
        </div>
        <span class="text-xs <%= prescription.active? ? 'bg-rose-100 text-rose-500' : 'bg-zinc-100 text-zinc-400' %> font-medium px-2 py-1 rounded-full">
          <%= prescription.active? ? t(".active") : t(".inactive") %>
        </span>
      </div>
    <% end %>
<% else %>
  <%= link_to prescription, class: "px-4 py-4 flex items-center justify-between border rounded-md border-rose-200 shadow-sm" do %>
    <div>
      <h5 class="font-semibold text-gray-800"><%= prescription.medication_version.full_name %></h5>
      <p class="text-xs text-rose-400 mt-0.5">
        <%= prescription.medication_version.medication.active_ingredients.map(&:name).to_sentence %>
      </p>
    </div>
    <span class="text-xs <%= prescription.active? ? 'bg-rose-100 text-rose-500' : 'bg-zinc-100 text-zinc-400' %> font-medium px-2 py-1 rounded-full">
      <%= prescription.active? ? t(".active") : t(".inactive") %>
    </span>
  <% end %>
<% end %>
