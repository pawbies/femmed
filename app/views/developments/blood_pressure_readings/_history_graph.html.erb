<div class="bg-white border border-rose-100 rounded-2xl overflow-hidden shadow-sm max-w-6xl mx-auto"
     data-controller="bp-history-graph"
     data-bp-history-graph-sys-value="<%= @bpr.map { |brp| { value: brp.systolic, measured_at: brp.measured_at }.compact }.compact.to_json %>"
     data-bp-history-graph-dia-value="<%= @bpr.map { |brp| { value: brp.diastolic, measured_at: brp.measured_at }.compact }.compact.to_json %>"
     data-bp-history-graph-bpm-value="<%= @bpr.map { |brp| { value: brp.bpm, measured_at: brp.measured_at }.compact }.compact.to_json %>"
     data-bp-history-graph-medications-value="<%= @prescriptions.map { |prescription| { id: prescription.id, name: prescription.full_name, created_at: prescription.created_at }.compact }.compact.to_json %>">

  <div class="px-5 pt-5 pb-3 flex items-start justify-between flex-wrap gap-3">
    <p class="text-xs font-semibold uppercase tracking-widest text-rose-300 pt-1"><%= t(".trend") %></p>
    <div class="flex items-center gap-3 text-xs text-zinc-500">
      <button type="button"
              data-bp-history-graph-target="toggle"
              data-series="sys"
              data-action="click->bp-history-graph#toggleSeries"
              class="flex items-center gap-1.5 cursor-pointer select-none transition-opacity">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-rose-500 shrink-0"></span>
        <span data-label><%= t(".systolic") %></span>
      </button>
      <button type="button"
              data-bp-history-graph-target="toggle"
              data-series="dia"
              data-action="click->bp-history-graph#toggleSeries"
              class="flex items-center gap-1.5 cursor-pointer select-none transition-opacity">
        <span class="inline-block w-2.5 h-2.5 rounded-full bg-orange-400 shrink-0"></span>
        <span data-label><%= t(".diastolic") %></span>
      </button>
      <button type="button"
              data-bp-history-graph-target="toggle"
              data-series="bpm"
              data-action="click->bp-history-graph#toggleSeries"
              class="flex items-center gap-1.5 cursor-pointer select-none transition-opacity">
        <span class="inline-block w-5 h-0 border-t-2 border-dashed border-indigo-400 shrink-0"></span>
        <span data-label><%= t(".heart_rate") %></span>
      </button>
    </div>
  </div>

  <div data-bp-history-graph-target="chart" class="w-full px-4 pb-2"></div>
</div>
