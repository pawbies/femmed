<div class="w-full">
  <h1 class="text-3xl font-semibold text-gray-800"><%= t(".blood_pressure_history") %></h1>

  <h3 class="text-2xl font-semibold text-gray-700 pb-3 border-b border-rose-100 mb-8">
    <span class="text-gray-400 font-normal italic">
      <%= "#{@pagy.count} #{t(".times_logged_count", count: @pagy.count)}" %>
    </span>
  </h3>

  <%= render "history_graph", bpr: @bpr, prescriptions: @prescriptions %>

  <%= render "partials/add_button", path: new_blood_pressure_reading_path %>
</div>
