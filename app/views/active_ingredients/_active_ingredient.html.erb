<%= link_to active_ingredient, class: "group flex items-center justify-between p-4 rounded-xl border border-rose-200 bg-white hover:border-rose-300 hover:bg-rose-50 transition-all" do %>
  <div>
    <p class="font-medium text-gray-900 group-hover:text-rose-500 transition-colors"><%= active_ingredient.name %></p>
    <div class="flex gap-3 mt-0.5">
      <% if active_ingredient.half_life.present? %>
        <p class="text-xs text-gray-400">t½ &nbsp;<span class="font-medium text-gray-500"><%= format("%g", active_ingredient.half_life) %>h</span></p>
        <p class="text-xs text-gray-400">ke &nbsp;<span class="font-medium text-gray-500"><%= format("%g", (Math.log(2)/active_ingredient.half_life).round(2)) %>/h</span></p>
      <% end %>
      <% if active_ingredient.absorption_rate.present? %>
        <p class="text-xs text-gray-400">ka &nbsp;<span class="font-medium text-gray-500"><%= format("%g", active_ingredient.absorption_rate) %>/h</span></p>
      <% end %>
      <% if active_ingredient.volume_of_distribution.present? %>
        <p class="text-xs text-gray-400">Vd &nbsp;<span class="font-medium text-gray-500"><%= format("%g", active_ingredient.volume_of_distribution) %>L</span></p>
      <% end %>
    </div>
  </div>
  <svg class="h-4 w-4 text-zinc-300 group-hover:text-rose-400 transition-colors shrink-0 ml-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
  </svg>
<% end %>
