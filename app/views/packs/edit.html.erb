<div class="w-full">
  <h1 class="font-bold text-center text-3xl">Edit pack of of <%= @prescription.full_name %></h1>

  <%= form_with model: [ @prescription, @pack ], class: "mt-10 mx-auto max-w-md" do |form| %>
    <% if @pack.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 p-4 mb-6">
        <h4 class="text-red-900 font-semibold mb-2">
          <%= pluralize(@pack.errors.count, "error") %> prohibited this pack from being saved:
        </h4>
        <ul class="list-disc list-inside text-red-800 space-y-1">
          <% @pack.errors.full_messages.each do |error| %>
            <li><%= error %></li>
          <% end %>
        </ul>
      </div>
    <% end %>


    <div class="my-5">
      <%= form.label :amount, "Amount of #{@prescription.form.name.pluralize}", class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <div class="flex items-center">
        <%= form.number_field :amount,
          required: true,
          autofocus: true,
          min: 1,
          placeholder: ":3",
          class: "shadow-sm rounded-l-md border bg-rose-50 border-rose-300 px-3 py-2 w-full" %>
        <span class="shadow-sm rounded-r-md border bg-rose-50 border-rose-300 px-3 py-2 w-min whitespace-nowrap">
          <%= @prescription.form.name.pluralize %>
        </span>
      </div>
    </div>

    <div class="my-5">
      <%= form.label :acquired_at, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.date_field :acquired_at,
        required: true,
        class: "shadow-sm rounded-md border bg-rose-50 border-rose-300 px-3 py-2 w-full" %>
    </div>

    <div class="mt-8 flex justify-center">
      <%= form.submit "Let's go and eat those meds!",
        class: "rounded-md px-6 py-3 bg-rose-400 hover:bg-rose-300 cursor-pointer font-medium" %>
    </div>
  <% end %>
</div>
