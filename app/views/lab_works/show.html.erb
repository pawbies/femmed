<% content_for(:title, t(".title", date: @lab_work.taken_at.strftime("%B %e, %Y"))) %>

<div class="w-full">
  <div class="flex flex-col md:flex-row justify-between">
    <div>
      <%= link_to lab_works_path, class: "inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-widest text-rose-300 hover:text-rose-400 transition-colors mb-3" do %>
        &#8592; <%= t(".back") %>
      <% end %>
      <h3 class="text-3xl font-semibold text-gray-800">
        <%= @lab_work.taken_at.strftime("%B %e, %Y") %>
        <span class="text-gray-400 font-normal text-2xl"><%= @lab_work.taken_at.strftime("at %H:%M") %></span>
      </h3>
    </div>
    <div class="my-6 md:my-0 flex items-center gap-2 md:self-start">
      <%= button_to @lab_work, method: :delete, data: { turbo_confirm: t(".confirm_delete") }, class: "inline-flex items-center justify-center w-9 h-9 rounded-lg border border-zinc-200 bg-white hover:bg-rose-50 hover:border-rose-300 transition-colors cursor-pointer" do %>
        <%= image_tag "icons/delete.svg", class: "h-4 w-4" %>
      <% end %>
    </div>
  </div>

  <div class="mt-8">
    <% if @lab_work.results.empty? %>
      <div class="text-center py-16 text-gray-400 text-sm">
        <%= t(".no_results") %>
      </div>
    <% else %>
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-zinc-200 text-left text-xs uppercase tracking-widest text-rose-300">
            <th class="pb-3 pr-6"><%= t(".marker") %></th>
            <th class="pb-3 pr-6"><%= t(".value") %></th>
            <th class="pb-3 pr-6"><%= t(".unit") %></th>
            <th class="pb-3 pr-6"><%= t(".reference_range") %></th>
            <th class="pb-3"><%= t(".status") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
          <% @lab_work.results.each do |result| %>
            <% bm = result.bio_marker %>
            <% has_range = bm.min_reference_value.present? && bm.max_reference_value.present? %>
            <% in_range = has_range && result.value.to_f >= bm.min_reference_value.to_f && result.value.to_f <= bm.max_reference_value.to_f %>
            <% too_low  = has_range && result.value.to_f < bm.min_reference_value.to_f %>
            <% too_high = has_range && result.value.to_f > bm.max_reference_value.to_f %>
            <tr class="transition-colors hover:bg-zinc-50">
              <td class="py-3.5 pr-6">
                <p class="font-semibold text-zinc-800"><%= bm.name %></p>
                <% if bm.abbreviation.present? %>
                  <p class="text-xs text-zinc-400"><%= bm.abbreviation %></p>
                <% end %>
              </td>
              <td class="py-3.5 pr-6 font-bold text-zinc-800 text-base tabular-nums">
                <%= result.value %>
              </td>
              <td class="py-3.5 pr-6 text-zinc-500">
                <%= bm.unit %>
              </td>
              <td class="py-3.5 pr-6 text-zinc-500 tabular-nums">
                <% if has_range %>
                  <%= bm.min_reference_value %> – <%= bm.max_reference_value %>
                <% else %>
                  <span class="text-zinc-300"><%= t(".no_range") %></span>
                <% end %>
              </td>
              <td class="py-3.5">
                <% if !has_range %>
                  <span class="text-zinc-300 text-xs font-medium"><%= t(".no_range") %></span>
                <% elsif in_range %>
                  <span class="inline-flex items-center rounded-full bg-emerald-50 border border-emerald-200 px-2.5 py-0.5 text-xs font-semibold text-emerald-700">
                    <%= t(".normal") %>
                  </span>
                <% elsif too_low %>
                  <span class="inline-flex items-center rounded-full bg-blue-50 border border-blue-200 px-2.5 py-0.5 text-xs font-semibold text-blue-700">
                    <%= t(".low") %>
                  </span>
                <% elsif too_high %>
                  <span class="inline-flex items-center rounded-full bg-rose-50 border border-rose-200 px-2.5 py-0.5 text-xs font-semibold text-rose-700">
                    <%= t(".high") %>
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>

  <%= render "partials/add_button", path: new_lab_work_result_path(@lab_work) %>
</div>
