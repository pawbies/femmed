<div class="relative w-full mx-auto aspect-4/2.5 rounded-lg overflow-hidden">
  <%= image_tag "pharmacy.svg", class: "absolute inset-0 w-full object-cover drop-shadow-sm [filter:drop-shadow(0_10px_8px_rgba(0,0,0,0.06))] z-10" %>

  <% if alert %>
    <div class="absolute top-4 md:top-16 left-1/2 -translate-x-[80%] max-w-sm border border-red-300 bg-red-50 rounded-2xl px-4 py-3 shadow-sm z-30
                after:content-[''] after:absolute after:right-6 after:-bottom-2
                after:w-4 after:h-4 after:bg-red-50 after:border-b after:border-r after:border-red-300
                after:rotate-45">
      <p class="text-gray-700"><%= alert %></p>
    </div>
  <% elsif notice %>
    <div class="absolute top-4 md:top-16 left-1/2 -translate-x-[80%] max-w-sm bg-white border border-rose-200 rounded-2xl px-4 py-3 shadow-sm z-30
                after:content-[''] after:absolute after:right-6 after:-bottom-2
                after:w-4 after:h-4 after:bg-white after:border-b after:border-r after:border-rose-200
                after:rotate-45">
      <p class="text-gray-700"><%= notice %></p>
    </div>
  <% end %>
</div>

<% unless current_page? root_path %>
  <nav class="mt-4 flex items-center justify-center">
    <%= link_to root_path, class: "group inline-flex items-center gap-2 text-xs uppercase tracking-[0.2em] text-rose-400 hover:text-rose-500 transition-colors" do %>
      <svg class="w-3 h-3 transition-transform duration-200 group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M15 18l-6-6 6-6" />
      </svg>
      <span class="border-b border-transparent group-hover:border-rose-300"><%= t(".back_to_home") %></span>
    <% end %>
  </nav>
<% end %>
