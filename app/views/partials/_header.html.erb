<% unless hotwire_native_app? %>
  <header class="px-6 py-8 flex justify-between items-center">
    <h1 class="text-3xl font-semibold flex items-center">
      <img src="/icon.svg" alt="<%= t(".logo_alt") %>" class="aspect-square h-24 mr-3">
      <%= link_to "FemMed", root_path %>
    </h1>

    <% if authenticated? %>
      <div class="relative flex items-center" data-controller="profile">
        <%= image_tag Current.user.profile_picture, data: { action: "click->profile#toggle" }, alt: t(".profile_alt"), class: "hover:cursor-pointer rounded-full border border-black aspect-square h-14" %>

        <div data-profile-target="popup" class="hidden absolute top-16 right-0 py-2 px-4 rounded-xl border border-rose-300 bg-rose-50 shadow-md">
          <%= link_to t(".profile"), Current.user, class: "text-lg font-semibold" %>
          <%= button_to t(".log_out"), session_path, method: :delete, class: "hover:cursor-pointer text-nowrap text-lg text-red-500 font-semibold" %>
        </div>

        <div class="js:hidden border-l ml-1 pl-1 flex flex-col items-left">
          <%= link_to t(".profile"), Current.user, class: "text-lg font-semibold" %>
          <%= button_to t(".log_out"), session_path, method: :delete, class: "hover:cursor-pointer text-nowrap text-lg text-red-500 font-semibold" %>
        </div>
      </div>
    <% end %>
  </header>
<% end %>
