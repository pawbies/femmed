<div class="w-full">

  <% unless authenticated? && admin? %>
    <img src="/icon.svg" alt="<%= t(".logo_alt") %>" class="mx-auto aspect-square max-w-32">
    <h1 class="mt-6 text-center font-semibold text-3xl text-gray-800"><%= t(".title") %></h1>
    <h2 class="mt-3 text-center text-xl text-gray-500"><%= t(".subtitle") %></h2>
  <% else %>
    <h1 class="font-semibold text-center text-3xl text-gray-800"><%= t(".admin_title") %></h1>
  <% end %>

  <%= form_with model: @user, class: "mt-10 mx-auto max-w-md" do |form| %>
    <% if @user.errors.any? %>
      <h3 class="text-xl text-center text-red-500">
        <% unless admin? %>
        <%= t(".error_heading") %>
        <% else %>
          <%= t(".admin_error_heading") %>
        <% end %>
      </h3>
      <ul class="list-disc">
        <% @user.errors.full_messages.each do |error| %>
          <li class="text-red-500"><%= error %></li>
        <% end %>
      </ul>
    <% end %>

    <div class="my-5">
      <%= form.label :email_address, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.email_field :email_address,
            required: true,
            autofocus: true,
            autocomplete: "username",
            placeholder: admin? ? t(".admin_email_placeholder") : t(".email_placeholder"),
            class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>
    <div class="my-5">
      <%= form.label :username, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.text_field :username,
        required: true,
        placeholder: admin? ? t(".admin_username_placeholder") : t(".username_placeholder"),
        class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>
    <div class="my-5">
      <%= form.label :password, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.password_field :password,
        required: true,
        autocomplete: "new-password",
        placeholder: admin? ? t(".admin_password_placeholder") : t(".password_placeholder"),
        maxlength: 72,
        class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>
    <div class="my-5">
      <%= form.label :password_confirmation, class: "block text-xs font-semibold uppercase tracking-widest text-rose-400 mb-2" %>
      <%= form.password_field :password_confirmation,
        required: true,
        autocomplete: "new-password",
        placeholder: admin? ? t(".admin_password_confirmation_placeholder") : t(".password_confirmation_placeholder"),
        maxlength: 72, class: "shadow-sm rounded-lg border bg-rose-50 border-rose-300 px-4 py-2.5 w-full text-gray-800 placeholder-rose-300 focus:outline-none focus:ring-2 focus:ring-rose-300 focus:border-transparent transition" %>
    </div>
    <div class="my-5 flex items-start gap-3">
      <%= form.check_box :terms_of_service, required: true, class: "mt-1 accent-rose-400 w-4 h-4 shrink-0 cursor-pointer" %>
      <%= form.label :terms_of_service, class: "text-sm text-gray-600 cursor-pointer" do %>
        <%= admin? ? t(".admin_accept") : t(".accept") %> <%= link_to t(".terms_of_service"), terms_of_service_path, class: "underline hover:no-underline text-rose-500" %>
      <% end %>
    </div>
    <div class="mt-8 flex justify-center">
      <%= form.submit t(".submit"), class: "rounded-lg px-6 py-2.5 bg-rose-400 hover:bg-rose-500 text-white cursor-pointer font-semibold transition-colors shadow-sm" %>
    </div>
  <% end %>

  <% unless admin? %>
    <div class="mt-16 flex justify-evenly items-center max-w-md mx-auto">
      <%= link_to t(".login_link"), new_session_path, class: "text-xl underline hover:no-underline" %>
    </div>
  <% end %>
</div>
