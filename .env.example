# Required — generate these with: bin/rails secret (for SECRET_KEY_BASE)
# and: bin/rails db:encryption:init (for the Active Record encryption keys)
SECRET_KEY_BASE=
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Your server's hostname or IP address (used for host authorization)
# Examples: 192.168.1.100  /  meds.example.com  /  localhost
APP_HOST=

# Set to true to allow anyone to register an account.
# Set to false to disable new registrations after your initial setup.
FEMMED_PUBLIC=true
